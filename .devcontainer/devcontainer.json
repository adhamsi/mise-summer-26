{
  "name": "Intro to Python Class",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bullseye",
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "files.autoSave": "afterDelay",
        
        // --- DISPLAY & WORKBENCH LAYOUT SETTINGS ---
        "workbench.panel.defaultVisibility": "hidden",
        "workbench.sideBar.location": "left",
        "workbench.activityBar.location": "hidden",
        "editor.minimap.enabled": false,                     
        "workbench.editor.showTabs": "multiple",

        // --- CLEAR TERMINAL ON RUN ---
        // This forces the integrated terminal to wipe old output when clicking the Play button
        "python.terminal.executeInFileDir": true,
        "python.terminal.clearPreviousOnExecute": true,
        "terminal.integrated.clearBeforeReusing": true,

        // --- DISABLE AI FEATURES ---
        // Hides Copilot buttons, inline suggestions, and setup prompts
        "github.copilot.enable": {
          "*": false
        },
        "github.copilot.editor.enableAutoCompletions": false,
        "inlineChat.acceptedWidgetPlacement": "hidden",
        "workbench.layoutControl.enabled": false
      }
    }
  }
}
