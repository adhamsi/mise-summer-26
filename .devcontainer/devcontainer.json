{
  "name": "Intro to Python Class",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bullseye",
  
  // This automatically installs extensions into their browser-based VS Code
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",       // Official Python extension (Linter, IntelliSense)
        "ms-python.vscode-pylance" // Fast, robust language support
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "files.autoSave": "afterDelay" // Highly recommended for beginners!
      }
    }
  }
}
